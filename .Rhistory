library(arrow)
library(tidyverse)
library(magrittr)
## Some of the sensors produce missing data, which screws up parquet reads.
## This reads everything as string, "fixing" that issue.
# Step 1: Open the dataset to get column names
ds <- open_dataset("s3://mco-mesonet/air-quality")
# Step 2: Create a schema with all columns as string
default_schema <- schema(!!!set_names(rep(list(string()), length(names(ds))), names(ds)))
# Step 3: Re-open the dataset with the default schema and filter
ds_fixed <- open_dataset("s3://mco-mesonet/air-quality", schema = default_schema) %>%
filter(station == "mcolubre") %>%
collect()
default_schema
ds_fixed
open_dataset("s3://mco-mesonet/air-quality", schema = default_schema)
ds_fixed <-
open_dataset("s3://mco-mesonet/air-quality", schema = default_schema) %>%
filter(station == "mcolubre") %>%
compute()
# Step 2: Inspect column types
types <- ds$schema$fields
# Step 3: Identify fields with null or problematic types
# This is a simplified heuristic: you may need to inspect actual files for full accuracy
problematic_fields <-
names(types)[map_lgl(types, ~ inherits(.x$type, "NullType"))]
# Step 4: Build a schema that sets only problematic fields to string
custom_schema <- schema(!!!set_names(
map(names(types), function(name) {
if (name %in% problematic_fields) string() else types[[name]]$type
}),
names(types)
))
custom_schema
problematic_fields
types
problematic_fields
names(types)[map_lgl(types, ~ inherits(.x$type, "NullType"))]
# Step 3: Identify fields with null or problematic types
# This is a simplified heuristic: you may need to inspect actual files for full accuracy
problematic_fields <-
names(types)[map_lgl(types, ~ inherits(.x$type, "null"))]
problematic_fields
# Step 3: Identify fields with null or problematic types
# This is a simplified heuristic: you may need to inspect actual files for full accuracy
problematic_fields <-
names(types)[map_lgl(types, ~ inherits(.x$type, "NullType"))]
problematic_fields
types
types[[11]]
types[[11]] %>% str
types[[11]]$nullable
types[[11]]$Equals()
types[[11]]$Equals("NullType")
types[[9]]$nullable
types[[9]]
types[[9]]$name
types[[9]]$type
types[[11]]$type
types[[11]]$type$name
class(types[[11]]$type)
